# ===========================================
# YouTube Automation Platform - Environment Variables
# Copy this file to .env and fill in the values
# ===========================================

# ===========================================
# Database Configuration
# ===========================================
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_NAME=youtube_automation
DATABASE_URL=postgresql+asyncpg://postgres:your-secure-password@localhost:5432/youtube_automation

# ===========================================
# Redis Configuration
# ===========================================
REDIS_URL=redis://localhost:6379/0

# ===========================================
# Security
# ===========================================
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# ===========================================
# Application
# ===========================================
ENVIRONMENT=development
DEBUG=false

# ===========================================
# Frontend
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=YouTube Automation Platform
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# YouTube OAuth (Get from Google Cloud Console)
# ===========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ===========================================
# Optional: Monitoring
# ===========================================
# FLOWER_BASIC_AUTH=admin:password
# SENTRY_DSN=your-sentry-dsn
